<?xml version="1.0" encoding="utf-8"?>
<!-- MSBuild targets for Bcsv NuGet package consumers.
     Copies the correct native library (bcsv_c_api) to the output directory
     based on the consumer's RuntimeIdentifier. -->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64' OR ('$(RuntimeIdentifier)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Windows)))' == 'true')">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\bcsv_c_api.dll"
             Link="bcsv_c_api.dll"
             CopyToOutputDirectory="PreserveNewest"
             Condition="Exists('$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\bcsv_c_api.dll')" />
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-x64' OR ('$(RuntimeIdentifier)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'true' AND '$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'X64')">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\libbcsv_c_api.so"
             Link="libbcsv_c_api.so"
             CopyToOutputDirectory="PreserveNewest"
             Condition="Exists('$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\libbcsv_c_api.so')" />
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-arm64' OR ('$(RuntimeIdentifier)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'true' AND '$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'Arm64')">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\linux-arm64\native\libbcsv_c_api.so"
             Link="libbcsv_c_api.so"
             CopyToOutputDirectory="PreserveNewest"
             Condition="Exists('$(MSBuildThisFileDirectory)..\runtimes\linux-arm64\native\libbcsv_c_api.so')" />
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'osx-x64' OR ('$(RuntimeIdentifier)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'true' AND '$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'X64')">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\osx-x64\native\libbcsv_c_api.dylib"
             Link="libbcsv_c_api.dylib"
             CopyToOutputDirectory="PreserveNewest"
             Condition="Exists('$(MSBuildThisFileDirectory)..\runtimes\osx-x64\native\libbcsv_c_api.dylib')" />
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'osx-arm64' OR ('$(RuntimeIdentifier)' == '' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'true' AND '$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'Arm64')">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\osx-arm64\native\libbcsv_c_api.dylib"
             Link="libbcsv_c_api.dylib"
             CopyToOutputDirectory="PreserveNewest"
             Condition="Exists('$(MSBuildThisFileDirectory)..\runtimes\osx-arm64\native\libbcsv_c_api.dylib')" />
  </ItemGroup>

</Project>
