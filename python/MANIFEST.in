include README.md
include LICENSE
include VERSION.txt
include pybcsv/py.typed
recursive-include pybcsv *.pyi

# Include top-level headers bundled for distribution
recursive-include include *.h
recursive-include include *.hpp
recursive-include include *.c

# Only include C/C++ sources from the python package that are intentionally shipped
include pybcsv/bindings.cpp

# Only exclude files if these folders exist and contain files
prune tests
prune examples
global-exclude *.pyc
global-exclude __pycache__
global-exclude .DS_Store
# Bundled CLI tool sources (synced by sync_headers.py; compiled into the wheel)
recursive-include src *.cpp
recursive-include src *.h
recursive-include src *.hpp
